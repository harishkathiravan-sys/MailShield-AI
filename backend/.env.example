# Database
DATABASE_URL=sqlite:///./mailshield.db
# For PostgreSQL: postgresql://mailshield:securepass123@localhost:5432/mailshield

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Keys (Optional but recommended)
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
PHISHTANK_API_KEY=

# Sandbox Configuration
SANDBOX_TIMEOUT=30
MAX_REDIRECTS=10
SANDBOX_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Analysis Configuration
SPAM_THRESHOLD=0.6
PHISHING_THRESHOLD=0.7
DOMAIN_AGE_SUSPICIOUS_DAYS=30
